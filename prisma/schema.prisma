datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// সার্ভার কনফিগারেশন টেবিল
model GuildConfig {
  guildId        String  @id
  logChannel     String?
  welcomeChannel String?
  ticketCategory String?
}

// ইউজার ওয়ার্নিং টেবিল
model UserWarning {
  id      String @id @default(cuid())
  userId  String
  guildId String
  count   Int    @default(0)

  @@unique([userId, guildId])
}

// ডিলিট হওয়া মেসেজ রিস্টোর টেবিল
model DeletedMessage {
  id        String   @id @default(cuid())
  content   String
  authorId  String
  authorTag String
  channelId String
  guildId   String
  createdAt DateTime @default(now())
}
