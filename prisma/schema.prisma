datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL") // v6 এ এটি সম্পূর্ণ সাপোর্ট করে এবং একদম স্ট্যাবল
}

generator client {
  provider = "prisma-client-js"
}

// সার্ভার কনফিগারেশন টেবিল
model GuildConfig {
  guildId        String  @id
  logChannel     String?
  welcomeChannel String?
  ticketCategory String?
}

// ইউজার ওয়ার্নিং টেবিল
model UserWarning {
  id      String @id @default(cuid())
  userId  String
  guildId String
  count   Int    @default(0)

  @@unique([userId, guildId])
}
